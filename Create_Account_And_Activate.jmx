            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">int rowCount = Integer.parseInt(vars.get(&quot;DebitCardNo_matchNr&quot;))
List&lt;Map&gt; candidates = []

for (int i = 1; i &lt;= rowCount; i++) {
    String debitCard = vars.get(&quot;DebitCardNo_&quot; + i)
    if (debitCard == null || debitCard.trim().isEmpty()) {
        Map customer = [
            name: vars.get(&quot;Name_&quot; + i),
            dob: vars.get(&quot;DOB_&quot; + i),
            pan: vars.get(&quot;PAN_&quot; + i),
            mobile: vars.get(&quot;Mobile_&quot; + i),
            accountNo: vars.get(&quot;AccountNo_&quot; + i)
        ]
        candidates.add(customer)
    }
}

// Randomly select one
if (!candidates.isEmpty()) {
    def chosen = candidates[new Random().nextInt(candidates.size())]
    log.info(&quot;Chosen customer: &quot; + chosen)
    vars.put(&quot;SelectedName&quot;, chosen.name)
    vars.put(&quot;SelectedDOB&quot;, chosen.dob)
    vars.put(&quot;SelectedPAN&quot;, chosen.pan)
    vars.put(&quot;SelectedMobile&quot;, chosen.mobile)
    vars.put(&quot;SelectedAccountNo&quot;, chosen.accountNo)
}
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Sampler>
